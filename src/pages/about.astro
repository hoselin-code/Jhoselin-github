---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FaJs, FaReact, FaNodeJs, FaPython } from 'react-icons/fa';
import { SiTypescript, SiAstro } from 'react-icons/si';

// Competencias Profesionales
const skills = [
  { 
    name: "Photoshop", 
    level: 80, 
    icon: FaJs
  },
  { 
    name: "Premiere Pro", 
    level: 60, 
    icon: FaJs
  },
  { 
    name: "After Effects", 
    level: 70, 
    icon: FaJs
  },
  { 
    name: "Audition", 
    level: 50, 
    icon: FaJs
  },
  { 
    name: "Autodesk Fusion", 
    level: 50, 
    icon: FaJs
  },
  { 
    name: "DaVinci Resolve", 
    level: 30, 
    icon: SiTypescript
  },
  { 
    name: "Affinity", 
    level: 60, 
    icon: FaReact
  },
  { 
    name: "Latex", 
    level: 70, 
    icon: FaNodeJs
  },
  { 
    name: "Ligthroom", 
    level: 60, 
    icon: FaPython
  },
  { 
    name: "Ilustrator", 
    level: 60, 
    icon: SiAstro
  }
];

// Experiencia Profesional
// Aquí puedes cambiar "startDate" y "endDate" por lo que necesites
const moreSkills = [
  { 
    name: "Asociación Astronómica Metzteocuitlatl", 
    level: 100, 
    startDate: "2023",
    endDate: "Actualidad"
  },
  { 
    name: "Asesor Académico en Centro de Bachillerato Tecnológico industrial y de servicios No. 16 (Prácticas Profesionales)", 
    level: 100, 
    startDate: "Ago 2024",
    endDate: "Dic 2024"
  },
   { 
    name: "Creador de Contenido en Descubriendo Pequeños Científicos (Servicio Social)", 
    level: 100,
    startDate: "Ene 2023",
    endDate: "Jul 2023"
  },
  { 
    name: "Edición de Video", 
    level: 90,
    startDate: "2014",
    endDate: "Actualidad"
  },
  { 
    name: "Diseño Gráfico", 
    level: 85, 
    startDate: "Ene 2023",
    endDate: "Actualidad"
  },
];
---

<BaseLayout title="Acerca de mí" description="Conozca más sobre mis habilidades y experiencia.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12 md:py-16 theme-transition-all">
    <div class="relative mb-12 sm:mb-16 md:mb-20">
      <div class="absolute -top-10 sm:-top-20 -left-10 sm:-left-20 w-36 sm:w-48 md:w-72 h-36 sm:h-48 md:h-72 bg-zinc-100 dark:bg-zinc-800/30 rounded-full blur-3xl opacity-30 animate-blob theme-transition-bg"></div>
      <div class="absolute -bottom-10 sm:-bottom-20 -right-10 sm:-right-20 w-36 sm:w-48 md:w-72 h-36 sm:h-48 md:h-72 bg-zinc-200 dark:bg-zinc-800/30 rounded-full blur-3xl opacity-30 animate-blob animation-delay-2000 theme-transition-bg"></div>
      
      <div class="relative grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-center">
        <div class="order-2 md:order-1 text-center md:text-left">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4 sm:mb-6 theme-transition-color">
            Jerry Aneck <span class="text-transparent bg-clip-text bg-gradient-to-r from-zinc-500 to-zinc-900 dark:from-zinc-300 dark:to-zinc-100 theme-transition-all">Romero Hernández</span>
          </h1>
          
          <p class="text-lg sm:text-xl text-zinc-600 dark:text-zinc-400 mb-6 sm:mb-8 leading-relaxed theme-transition-color">
            Egresado de la Licenciatura en Física con experiencia en divulgación científica, diseño y educación.
          </p>
          
          <div class="flex flex-wrap gap-4 social-links-container justify-center md:justify-start theme-transition-children">
            </div>
        </div>
        
        <div class="order-1 md:order-2 relative">
          <div class="aspect-square w-full max-w-[280px] sm:max-w-[320px] md:max-w-md mx-auto overflow-hidden rounded-3xl border-4 sm:border-8 border-white dark:border-zinc-800 shadow-xl sm:shadow-2xl theme-transition-all">
            <img 
              src="/perfil.jpg" 
              alt="Profile photo" 
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          
          <div class="absolute -bottom-4 sm:-bottom-6 -right-4 sm:-right-6 w-16 sm:w-20 md:w-24 h-16 sm:h-20 md:h-24 bg-zinc-100 dark:bg-zinc-800 rounded-full border-2 sm:border-4 border-white dark:border-zinc-900 shadow-lg flex items-center justify-center theme-transition-all">
            <span class="text-2xl sm:text-3xl">👋</span>
          </div>
        </div>
      </div>
    </div>
    
    <div class="mb-16 sm:mb-20 md:mb-24 theme-transition-all">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 sm:mb-8 flex items-center justify-center md:justify-start theme-transition-color">
          <span class="hidden sm:inline-block w-8 sm:w-12 h-1 bg-zinc-300 dark:bg-zinc-700 mr-4 theme-transition-bg"></span>
          Acerca de mí
          <span class="hidden sm:inline-block w-8 sm:w-12 h-1 bg-zinc-300 dark:bg-zinc-700 ml-4 theme-transition-bg"></span>
        </h2>
        
        <div class="prose prose-zinc dark:prose-invert max-w-none theme-transition-all">
          <p class="text-base sm:text-lg leading-relaxed mb-4 sm:mb-6 theme-transition-color">
            Miembro fundador de la Asociación Astronómica Metzteocuitlatl. Experiencia en creación de contenido visual, diseñador de contenido educativo STEM, eventos de divulgación y producción multimedia. Apasionado
            por hacer accesible la ciencia mediante herramientas digitales y creativas.
          </p>
        </div>
      </div>
    </div>
    
    <div class="mb-16 theme-transition-all">
      <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-8 sm:mb-12 text-center theme-transition-color">Competencias Profesionales</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          {skills.map((skill, index) => (
            <div key={`${skill.name}-${index}`} class="skill-card bg-white dark:bg-zinc-800/50 rounded-xl border border-zinc-200 dark:border-zinc-700 hover:border-zinc-300 dark:hover:border-zinc-600 transition-all duration-300 hover:shadow-lg theme-transition-element">
              <div class="p-4 sm:p-6">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 flex items-center justify-center bg-zinc-100 dark:bg-zinc-800 rounded-lg text-zinc-800 dark:text-zinc-200 transform transition-transform group-hover:rotate-12 theme-transition-bg theme-transition-color">
                      <skill.icon size={20} className="transform transition-all" />
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 theme-transition-color">{skill.name}</h3>
                  </div>
                  <span class="text-xs font-mono bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-2.5 py-1 rounded-full theme-transition-all">{skill.level}%</span>
                </div>
                
                <div class="relative h-2 w-full bg-zinc-100 dark:bg-zinc-700 overflow-hidden rounded-full theme-transition-bg">
                  <div 
                    class="absolute top-0 left-0 h-full bg-gradient-to-r from-zinc-700 via-zinc-600 to-zinc-800 dark:from-zinc-300 dark:via-zinc-400 dark:to-zinc-200 rounded-full theme-transition-bg"
                    style={`width: ${skill.level}%`}
                  ></div>
                </div>
                
                <div class="flex justify-between mt-2 text-xs text-zinc-400 dark:text-zinc-500 font-mono theme-transition-color">
                  <span>Principiante</span>
                  <span>Avanzado</span>
                </div>
              </div>
            </div>
          ))}
      </div>
    </div>

    <div class="mb-16 sm:mb-20 md:mb-24 theme-transition-all">
      <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-8 sm:mb-12 text-center theme-transition-color">Experiencia Profesional</h2>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          {moreSkills.map((skill, index) => (
            <div key={`${skill.name}-dup-${index}`} class="skill-card bg-white dark:bg-zinc-800/50 rounded-xl border border-zinc-200 dark:border-zinc-700 hover:border-zinc-300 dark:hover:border-zinc-600 transition-all duration-300 hover:shadow-lg theme-transition-element">
              <div class="p-4 sm:p-6">
                <div class="flex items-center justify-between mb-4">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 flex items-center justify-center bg-zinc-100 dark:bg-zinc-800 rounded-lg text-zinc-800 dark:text-zinc-200 transform transition-transform group-hover:rotate-12 theme-transition-bg theme-transition-color">
                      <skill.icon size={20} className="transform transition-all" />
                    </div>
                    <h3 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 theme-transition-color">{skill.name}</h3>
                  </div>
                  <span class="text-xs font-mono bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 px-2.5 py-1 rounded-full theme-transition-all">{skill.level}%</span>
                </div>
                
                              
                <div class="flex justify-between mt-2 text-xs text-zinc-400 dark:text-zinc-500 font-mono theme-transition-color">
                  <span>{skill.startDate}</span>
                  <span>{skill.endDate}</span>
                </div>
              </div>
            </div>
          ))}
      </div>
    </div>
    
    <div class="max-w-3xl mx-auto text-center theme-transition-all">
      <h2 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 mb-4 sm:mb-6 theme-transition-color">Contáctame</h2>
      <p class="text-base sm:text-lg text-zinc-600 dark:text-zinc-400 mb-6 sm:mb-8 theme-transition-color">
        Enviame un correo.
      </p>
      
      <a 
        href="mailto:jerryaneck@outlook.com" 
        class="inline-flex items-center justify-center px-6 sm:px-8 py-3 sm:py-4 rounded-lg bg-zinc-900 dark:bg-zinc-100 text-zinc-100 dark:text-zinc-900 hover:bg-zinc-700 dark:hover:bg-zinc-300 transition-colors text-base sm:text-lg font-medium theme-transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 sm:h-5 sm:w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        ¡Hola!
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  /* Blob animation */
  .animate-blob {
    animation: blob-bounce 8s infinite ease;
  }
  
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  @keyframes blob-bounce {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(5%, 5%) scale(1.05); }
    50% { transform: translate(0, 10%) scale(1); }
    75% { transform: translate(-5%, 5%) scale(0.95); }
  }
  
  /* Cards Styling */
  .skill-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  .skill-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }
  
  .skill-card:before {
    content: '';
    position: absolute;
    top: -10%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at center, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  
  .skill-card:hover:before {
    opacity: 1;
  }

  /* Theme transition effect */
  :global(.theme-switching) .theme-transition-element {
    animation: fadeIn 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  .skill-card.theme-transition-element {
    transition: background-color var(--theme-transition), 
                border-color var(--theme-transition), 
                color var(--theme-transition), 
                box-shadow var(--theme-transition),
                transform 0.3s ease;
  }
</style>

<script>
  function setupSPATransitions() {
    function animateAboutContent() {
      const heroElements = document.querySelectorAll('h1, .order-2 p, .social-links-container');
      heroElements.forEach((el, index) => {
        setTimeout(() => {
          el.classList.add('animate-reveal');
        }, 100 + (index * 150));
      });
      
      const skillCards = document.querySelectorAll('.skill-card');
      skillCards.forEach((card, index) => {
        setTimeout(() => {
          card.style.opacity = '1'; 
        }, 100 + (index * 50));
      });
    }
    animateAboutContent();
  }
  
  document.addEventListener('DOMContentLoaded', setupSPATransitions);
  document.addEventListener('astro:page-load', setupSPATransitions);
</script>