---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// LÓGICA ORIGINAL (Sin cambios)
const allPosts = await getCollection('blog');
const tags = [...new Set(allPosts.flatMap(post => post.data.tags || []))].sort();

const tagObjects = tags.map(tag => {
  const count = allPosts.filter(post => post.data.tags?.includes(tag)).length;
  const hue = Math.abs(tag.split('').reduce((acc, char) => acc + char.charCodeAt(0), 0) % 360);
  return { 
    name: tag, 
    count,
    // Ya no necesitamos 'size' para el diseño de tarjeta uniforme, pero lo dejo por si lo usas luego.
    size: Math.max(1, Math.min(3, Math.floor(count / 2) + 1)), 
    hue
  };
});

const sortedTags = [...tagObjects].sort((a, b) => b.count - a.count);
---

<BaseLayout title="Categorías">
  <div class="w-full mx-auto px-4 sm:px-6 py-8 sm:py-12 md:py-16 theme-transition-all">
    <div class="relative mb-10 sm:mb-16 text-center theme-transition-element">
      <div class="absolute -top-20 -left-20 w-48 sm:w-72 h-48 sm:h-72 bg-zinc-100 dark:bg-zinc-800/50 rounded-full blur-3xl opacity-50 animate-blob theme-transition-bg"></div>
      <div class="absolute -bottom-20 -right-20 w-48 sm:w-72 h-48 sm:h-72 bg-zinc-200 dark:bg-zinc-800/30 rounded-full blur-3xl opacity-30 animate-blob animation-delay-2000 theme-transition-bg"></div>
      
      <h1 class="relative text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4 theme-transition-color">
        <span class="inline-block relative">
          <span class="relative inline-block">
            <span class="absolute -inset-1 rounded-lg bg-gradient-to-r from-zinc-200/50 to-zinc-300/50 dark:from-zinc-800/50 dark:to-zinc-700/50 blur-sm theme-transition-bg"></span>
            <span class="relative">Explorar</span>
          </span>
          {" "}
          <span class="relative inline-block">
            Categorías
            <span class="absolute -bottom-2 left-0 w-full h-1 bg-gradient-to-r from-zinc-400 to-zinc-600 dark:from-zinc-600 dark:to-zinc-400 transform origin-left animate-underline theme-transition-bg"></span>
          </span>
        </span>
      </h1>
      <p class="relative text-base sm:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mx-auto theme-transition-color">
        Navega a través de todos los temas disponibles.
      </p>
    </div>
    
    {sortedTags.length === 0 ? (
      <div class="text-center py-16 theme-transition-element">
        <p class="text-xl font-medium text-zinc-800 dark:text-zinc-200 theme-transition-color">No se encontraron categorías.</p>
      </div>
    ) : (
      <div class="flex justify-center w-full">
        <div class="relative w-full p-4 sm:p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 bg-white/50 dark:bg-zinc-900/50 backdrop-blur-sm shadow-sm theme-transition-all">
          <div class="absolute inset-0 bg-grid-pattern opacity-5 dark:opacity-10 theme-transition-bg rounded-3xl"></div>
          
          <h2 class="text-xl sm:text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 sm:mb-8 text-center theme-transition-color">Temas Populares</h2>
          
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4 w-full">
            {sortedTags.map((tag) => (
              <a 
                href={`/tags/${tag.name}`}
                class="group relative overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800 transition-all duration-300 hover:shadow-md hover:-translate-y-1 hover:border-zinc-300 dark:hover:border-zinc-700 bg-white dark:bg-zinc-900 theme-transition-element theme-ripple flex flex-col h-full"
                style={`--tag-hue: ${tag.hue};`}
              >
                <div class="absolute inset-0 bg-gradient-to-br from-zinc-50/50 to-zinc-100/50 dark:from-zinc-800/50 dark:to-zinc-900/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 theme-transition-bg"></div>
                
                <div class="relative p-3 sm:p-4 flex items-start gap-3 w-full h-full">
                  <div class="flex-shrink-0 flex items-center justify-center w-8 h-8 sm:w-9 sm:h-9 rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 group-hover:bg-accent/10 dark:group-hover:bg-accent/20 group-hover:text-accent-dark dark:group-hover:text-accent-light transition-all duration-300 shadow-sm theme-transition-all" style={`color: hsl(${tag.hue}, 70%, 40%); background-color: hsl(${tag.hue}, 70%, 95%);`}>
                    <span class="text-sm sm:text-base font-bold">#</span>
                  </div>
                  
                  <div class="flex-1 min-w-0">
                    <h3 class="text-xs sm:text-sm font-bold text-zinc-800 dark:text-zinc-100 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors theme-transition-color break-words whitespace-normal leading-tight">
                      {tag.name}
                    </h3>
                    <p class="text-[10px] sm:text-xs text-zinc-500 dark:text-zinc-400 mt-1 theme-transition-color">
                      {tag.count} {tag.count !== 1 ? 'artículos' : 'artículo'}
                    </p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  // Script simplificado, eliminando la complejidad innecesaria de los breakpoints "micro"
  document.addEventListener('DOMContentLoaded', () => {
    // Fix para la altura en móviles (VH)
    const setVh = () => {
      const vh = window.innerHeight * 0.01;
      document.documentElement.style.setProperty('--vh', `${vh}px`);
    };
    setVh();
    window.addEventListener('resize', setVh);

    // Soporte táctil básico
    const addTouchSupport = () => {
      const tagItems = document.querySelectorAll('.theme-ripple');
      tagItems.forEach(item => {
        item.addEventListener('touchstart', () => item.classList.add('touch-active'), { passive: true });
        item.addEventListener('touchend', () => setTimeout(() => item.classList.remove('touch-active'), 150), { passive: true });
      });
    };
    addTouchSupport();
  });
</script>

<style>
  /* Estilos base simplificados */
  .bg-grid-pattern {
    background-size: 20px 20px;
    background-image: radial-gradient(circle, currentColor 1px, transparent 1px);
  }
  
  /* Animaciones */
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  @keyframes underline {
    0% { transform: scaleX(0); }
    100% { transform: scaleX(1); }
  }
  .animate-underline {
    animation: underline 1s ease-out forwards;
  }

  /* Touch active state */
  .touch-active {
    transform: scale(0.98);
    transition: transform 0.1s;
  }
</style>