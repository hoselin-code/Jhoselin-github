---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// 1. OBTENER BLOG POSTS
const allPosts = await getCollection('blog');

// 2. DEFINIR VIDEOS MANUALMENTE
const videos = [
  { title: "MECÁNICA I", tags: ["Física", "Mecánica", "YouTube"] },
  { title: "Gravedad", tags: ["Física", "Gravedad", "Historia"] },
  { title: "Agujeros Negros", tags: ["Astrofísica", "TikTok", "Cosmos"] },
  { title: "Fractales", tags: ["Matemáticas", "Arte", "TikTok"] }
];

// 3. COMBINAR ETIQUETAS
const blogTags = allPosts.flatMap(post => post.data.tags || []);
const videoTags = videos.flatMap(video => video.tags || []);
const allTagsRaw = [...blogTags, ...videoTags];
const uniqueTags = [...new Set(allTagsRaw)].sort();

// 4. CREAR OBJETOS
const tagObjects = uniqueTags.map(tag => {
  const postCount = allPosts.filter(post => post.data.tags?.includes(tag)).length;
  const videoCount = videos.filter(video => video.tags?.includes(tag)).length;
  const totalCount = postCount + videoCount;
  
  return { 
    name: tag, 
    count: totalCount
  };
});

const sortedTags = [...tagObjects].sort((a, b) => b.count - a.count);
---

<BaseLayout title="Categorías">
  <div class="w-full mx-auto px-4 sm:px-6 py-8 sm:py-12 md:py-16 theme-transition-all">
    <div class="relative mb-10 sm:mb-16 text-center theme-transition-element">
      <div class="absolute -top-20 -left-20 w-48 sm:w-72 h-48 sm:h-72 bg-zinc-100 dark:bg-zinc-800/50 rounded-full blur-3xl opacity-50 animate-blob theme-transition-bg"></div>
      <div class="absolute -bottom-20 -right-20 w-48 sm:w-72 h-48 sm:h-72 bg-zinc-200 dark:bg-zinc-800/30 rounded-full blur-3xl opacity-30 animate-blob animation-delay-2000 theme-transition-bg"></div>
      
      <h1 class="relative text-3xl sm:text-4xl md:text-6xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-4 theme-transition-color">
        <span class="inline-block relative">
          <span class="relative inline-block">
            <span class="absolute -inset-1 rounded-lg bg-gradient-to-r from-zinc-200/50 to-zinc-300/50 dark:from-zinc-800/50 dark:to-zinc-700/50 blur-sm theme-transition-bg"></span>
            <span class="relative">Explorar</span>
          </span>
          {" "}
          <span class="relative inline-block">
            Categorías
            <span class="absolute -bottom-2 left-0 w-full h-1 bg-gradient-to-r from-zinc-400 to-zinc-600 dark:from-zinc-600 dark:to-zinc-400 transform origin-left animate-underline theme-transition-bg"></span>
          </span>
        </span>
      </h1>
      <p class="relative text-base sm:text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mx-auto theme-transition-color">
        Navega a través de todos los temas disponibles.
      </p>
    </div>
    
    {sortedTags.length === 0 ? (
      <div class="text-center py-16 theme-transition-element">
        <p class="text-xl font-medium text-zinc-800 dark:text-zinc-200 theme-transition-color">No se encontraron categorías.</p>
      </div>
    ) : (
      <div class="flex justify-center w-full">
        <div class="relative w-full p-4 sm:p-8 rounded-3xl border border-zinc-100 dark:border-zinc-800 bg-white/50 dark:bg-zinc-900/50 backdrop-blur-sm shadow-sm theme-transition-all">
          <div class="absolute inset-0 bg-grid-pattern opacity-5 dark:opacity-10 theme-transition-bg rounded-3xl"></div>
          
          <h2 class="text-xl sm:text-2xl font-bold text-zinc-900 dark:text-zinc-100 mb-6 sm:mb-8 text-center theme-transition-color">Temas Populares</h2>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 w-full">
            {sortedTags.map((tag) => (
              <a 
                href={`/tags/${tag.name}`}
                class="group relative overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800 transition-all duration-300 hover:shadow-md hover:-translate-y-1 hover:border-zinc-400 dark:hover:border-zinc-600 bg-white dark:bg-zinc-900 theme-transition-element flex flex-col h-full"
              >
                <div class="absolute inset-0 bg-zinc-50 dark:bg-zinc-800 opacity-0 group-hover:opacity-100 transition-opacity duration-300 theme-transition-bg"></div>
                
                <div class="relative p-4 sm:p-5 flex items-start gap-4 w-full h-full">
                  <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-zinc-100 dark:bg-zinc-800 text-black dark:text-white border border-zinc-200 dark:border-zinc-700 transition-all duration-300 group-hover:scale-110">
                    <span class="text-lg font-bold">#</span>
                  </div>
                  
                  <div class="flex-1 min-w-0 pt-1">
                    <h3 class="text-base sm:text-lg font-bold text-zinc-900 dark:text-zinc-100 group-hover:text-black dark:group-hover:text-white transition-colors theme-transition-color break-words leading-tight">
                      {tag.name}
                    </h3>
                    <p class="text-xs sm:text-sm text-zinc-500 dark:text-zinc-400 mt-1 theme-transition-color">
                      {tag.count} {tag.count !== 1 ? 'publicaciones' : 'publicación'}
                    </p>
                  </div>
                  
                  <div class="self-center opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-zinc-400">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
                    </svg>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const setVh = () => {
      const vh = window.innerHeight * 0.01;
      document.documentElement.style.setProperty('--vh', `${vh}px`);
    };
    setVh();
    window.addEventListener('resize', setVh);

    const addTouchSupport = () => {
      const tagItems = document.querySelectorAll('.group');
      tagItems.forEach(item => {
        item.addEventListener('touchstart', () => item.classList.add('active'), { passive: true });
        item.addEventListener('touchend', () => setTimeout(() => item.classList.remove('active'), 150), { passive: true });
      });
    };
    addTouchSupport();
  });
</script>

<style>
  .bg-grid-pattern {
    background-size: 20px 20px;
    background-image: radial-gradient(circle, currentColor 1px, transparent 1px);
  }
  
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 7s infinite;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  
  @keyframes underline {
    0% { transform: scaleX(0); }
    100% { transform: scaleX(1); }
  }
  .animate-underline {
    animation: underline 1s ease-out forwards;
  }
</style>